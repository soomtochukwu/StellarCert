# Soroban Integration Environment Variables

# Enable Soroban smart contract integration
ENABLE_SOROBAN_INTEGRATION=true

# Soroban RPC endpoint
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Admin secret key for contract operations (keep secure!)
SOROBAN_ADMIN_SECRET=your_admin_secret_key_here

# Deployed contract IDs (obtained from deployment script)
CERTIFICATE_CONTRACT_ID=CCERTIFICATE_CONTRACT_ID_HERE
MULTISIG_CONTRACT_ID=CMULTISIG_CONTRACT_ID_HERE
CRL_CONTRACT_ID=CCRL_CONTRACT_ID_HERE

# Existing Stellar configuration
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK=testnet
STELLAR_ISSUER_SECRET_KEY=your_issuer_secret_key